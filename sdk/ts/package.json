{
  "name": "@atp-protocol/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Agent Trust Protocol (ATP) — governed execution for AI agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "atp",
    "agent-trust-protocol",
    "ai-agents",
    "governance",
    "mcp",
    "dual",
    "trust",
    "protocol"
  ],
  "author": "DUAL Network",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ATP-Protocol/atp-protocol.git",
    "directory": "sdk/ts"
  },
  "homepage": "https://github.com/ATP-Protocol/atp-protocol",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.0.0"
  }
}
