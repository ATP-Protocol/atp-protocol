{
  "name": "@atp-protocol/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Agent Trust Protocol (ATP) — governed execution for AI agents",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./contract": {
      "types": "./dist/cjs/contract/index.d.ts",
      "import": "./dist/esm/contract/index.js",
      "require": "./dist/cjs/contract/index.js"
    },
    "./policy": {
      "types": "./dist/cjs/policy/index.d.ts",
      "import": "./dist/esm/policy/index.js",
      "require": "./dist/cjs/policy/index.js"
    },
    "./approval": {
      "types": "./dist/cjs/approval/index.d.ts",
      "import": "./dist/esm/approval/index.js",
      "require": "./dist/cjs/approval/index.js"
    },
    "./governance": {
      "types": "./dist/cjs/governance/index.d.ts",
      "import": "./dist/esm/governance/index.js",
      "require": "./dist/cjs/governance/index.js"
    },
    "./evidence": {
      "types": "./dist/cjs/evidence/index.d.ts",
      "import": "./dist/esm/evidence/index.js",
      "require": "./dist/cjs/evidence/index.js"
    },
    "./credentials": {
      "types": "./dist/cjs/credentials/index.d.ts",
      "import": "./dist/esm/credentials/index.js",
      "require": "./dist/cjs/credentials/index.js"
    },
    "./execution": {
      "types": "./dist/cjs/execution/index.d.ts",
      "import": "./dist/esm/execution/index.js",
      "require": "./dist/cjs/execution/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "atp",
    "agent-trust-protocol",
    "ai-agents",
    "governance",
    "mcp",
    "dual",
    "trust",
    "protocol",
    "model-context-protocol"
  ],
  "author": "DUAL Network",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ATP-Protocol/atp-protocol.git",
    "directory": "sdk/ts"
  },
  "homepage": "https://github.com/ATP-Protocol/atp-protocol/tree/main/sdk/ts",
  "bugs": {
    "url": "https://github.com/ATP-Protocol/atp-protocol/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@types/pg": "^8.20.0",
    "pg": "^8.20.0",
    "pg-mem": "^3.0.14"
  }
}
