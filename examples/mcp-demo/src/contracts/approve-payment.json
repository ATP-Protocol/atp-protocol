{
  "version": "1.0.0",
  "authority": "org.finance.approve-payment",
  "template": "tpl_payment_approval",
  "actions": ["approve-payment"],
  "scope": {
    "currency": ["USD", "EUR", "GBP"],
    "max_amount": 50000,
    "approval_threshold": 10000,
    "transaction_type": ["vendor-payment", "expense-reimbursement"]
  },
  "approval": {
    "required": false,
    "required_above": 10000,
    "approver_role": "finance_controller",
    "timeout": "PT8H",
    "escalation_path": "cfo"
  },
  "credentials": {
    "provider": "banking-api",
    "scope": ["payments.process"],
    "inject_as": "api_key",
    "fail_closed": true
  },
  "output": {
    "object_type": "payment_record",
    "initial_state": "approved",
    "schema_ref": "schemas/payment-approval-v1.json"
  },
  "attestation": "full",
  "revocable": true,
  "expiry": "2027-12-31T23:59:59Z",
  "idempotency": "gateway-enforced"
}
