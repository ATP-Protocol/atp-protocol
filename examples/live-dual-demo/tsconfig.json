{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "paths": {
      "@atp-protocol/sdk": ["../../sdk/ts/src"],
      "@atp-protocol/gateway": ["../../gateway/src"]
    }
  },
  "include": ["src"]
}
