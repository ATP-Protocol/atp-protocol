{
  "name": "@atp-protocol/registry",
  "version": "0.1.0",
  "description": "ATP Contract Registry — publish, discover, and resolve governance contracts",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "atp",
    "registry",
    "contracts",
    "governance",
    "discovery"
  ],
  "author": "DUAL Network",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ATP-Protocol/atp-protocol.git",
    "directory": "registry"
  },
  "dependencies": {
    "@atp-protocol/sdk": "workspace:*"
  },
  "devDependencies": {
    "@atp-protocol/sdk": "^0.1.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.0.0"
  }
}
