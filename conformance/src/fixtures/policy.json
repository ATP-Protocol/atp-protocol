    {
      "name": "enum_permit_in_list",
      "description": "Enumeration constraint permits value in list",
      "contract": {
        "version": "1.0.0",
        "authority": "org.example.deploy",
        "actions": ["deploy"],
        "attestation": "full",
        "scope": {
          "environment": ["staging", "prod"]
        }
      },
      "params": { "environment": "staging" },
      "expected_permitted": true
    },
    {
      "name": "enum_deny_not_in_list",
